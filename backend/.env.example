# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/acapulco_db"

# ─── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="8h"

# ─── Server ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL="https://acapulco.vercel.app"

# ─── ERP - Sisplan (via Cloudflare Tunnel) ─────────────────────────────────
ERP_BASE_URL="https://erp.lourencosolucoesengenharia.com.br"
ERP_TOKEN="your-sisplan-api-token"
ERP_FRESHNESS_DAYS=15

# ─── OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─── Embroidery Pricing ────────────────────────────────────────────────────
EMBROIDERY_PRICE_PER_K=0.90
PRINT_PRICE_PER_CM2=0.003

# ─── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=info
